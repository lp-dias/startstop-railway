@model IEnumerable<StartStop.Models.Movimentacao>

<div class="container mt-4">
    <h2 class="mb-4">📋 Movimentações</h2>

    <!-- Mensagens de feedback -->
    @if (TempData["MensagemErro"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-lg" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            @TempData["MensagemErro"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
        </div>
    }

    @if (TempData["Mensagem"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-lg" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            @TempData["Mensagem"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
        </div>
    }

    <p>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i> Nova Retirada
        </a>
    </p>

    <div class="card shadow-lg">
        <div class="card-body">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Motorista</th>
                        <th>Veículo</th>
                        <th>Destino</th>
                        <th>Data Retirada</th>
                        <th>Data Retorno</th>
                        <th>Kms</th>
                        <th>Status</th>
                        <th>Tipo</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var mov in Model)
                {
                    <tr>
                        <td>@mov.Motorista?.Nome</td>
                        <td>@mov.Veiculo?.Placa</td>
                        <td>@mov.Destino</td>
                        <td>@mov.DataRetirada.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@(mov.DataRetorno.HasValue ? mov.DataRetorno.Value.ToString("dd/MM/yyyy HH:mm") : "-")</td>
                        <td>
                            Saída: @mov.KmSaida <br />
                            Retorno: @(mov.KmRetorno.HasValue ? mov.KmRetorno.ToString() : "-")
                        </td>
                        <td>@mov.Status</td>
                        <td>@mov.TipoMovimentacao</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@mov.Id" class="btn btn-info btn-sm">
                                <i class="bi bi-eye"></i> Detalhes
                            </a>
                            @if (mov.Status == "Pendente")
                            {
                                <form asp-action="CancelarRetirada" method="post" style="display:inline">
                                    <input type="hidden" name="movimentacaoId" value="@mov.Id" />
                                    <input type="hidden" name="motivo" value="Cancelado via tela" />
                                    <button type="submit" class="btn btn-warning btn-sm">
                                        <i class="bi bi-x-circle"></i> Cancelar
                                    </button>
                                </form>
                            }
                            @if (mov.Status == "Pendente" || mov.Status == "KmTolerancia")
                            {
                                <form asp-action="CreateDevolucao" method="post" style="display:inline">
                                    <input type="hidden" name="movimentacaoId" value="@mov.Id" />
                                    <input type="number" name="kmRetorno" placeholder="Km Retorno" required class="form-control form-control-sm d-inline-block" style="width:120px;" />
                                    <button type="submit" class="btn btn-success btn-sm">
                                        <i class="bi bi-arrow-return-left"></i> Devolver
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
