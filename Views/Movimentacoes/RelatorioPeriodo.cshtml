@model IEnumerable<StartStop.Models.Movimentacao>

<div class="container mt-4">
    <h2 class="mb-4">Relatório de Movimentações por Período</h2>

    <form method="get" class="row g-3 mb-4">
        <div class="col-md-4">
            <label for="inicio" class="form-label">Data Início</label>
            <input type="date" id="inicio" name="inicio" class="form-control" />
        </div>
        <div class="col-md-4">
            <label for="fim" class="form-label">Data Fim</label>
            <input type="date" id="fim" name="fim" class="form-control" />
        </div>
        <div class="col-md-4 d-flex align-items-end">
            <button type="submit" class="btn btn-primary">Filtrar</button>
        </div>
    </form>

    <table class="table table-striped table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Data Retirada</th>
                <th>Motorista</th>
                <th>Veículo</th>
                <th>Destino</th>
                <th>Km Saída</th>
                <th>Km Retorno</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.DataRetirada</td>
                    <td>@item.Motorista.Nome</td>
                    <td>@item.Veiculo.Placa</td>
                    <td>@item.Destino</td>
                    <td>@item.KmSaida</td>
                    <td>@item.KmRetorno</td>
                    <td>@item.Status</td>
                </tr>
            }
        </tbody>
    </table>
</div>
