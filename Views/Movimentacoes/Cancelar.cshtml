@model StartStop.Models.Movimentacao

<div class="container mt-4">
    <h2 class="mb-4">Cancelar Retirada</h2>

    <div class="card shadow-lg">
        <div class="card-body">
            <form asp-action="CancelarRetirada" method="post" class="row g-3">
                <input type="hidden" name="movimentacaoId" value="@Model.Id" />

                <div class="col-md-6">
                    <label class="form-label">Motorista</label>
                    <input type="text" class="form-control" value="@Model.Motorista?.Nome" readonly />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Veículo</label>
                    <input type="text" class="form-control" value="@Model.Veiculo?.Placa" readonly />
                </div>

                <div class="col-md-12">
                    <label for="motivo" class="form-label">Motivo do Cancelamento</label>
                    <textarea id="motivo" name="motivo" class="form-control" rows="3" placeholder="Informe o motivo" required></textarea>
                </div>

                <div class="col-12">
                    <button type="submit" class="btn btn-danger">Confirmar Cancelamento</button>
                    <a asp-action="Index" class="btn btn-secondary">Voltar</a>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Toasts para feedback -->
@if (TempData["Mensagem"] != null)
{
    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div class="toast show bg-primary text-white shadow-lg" role="alert">
            <div class="toast-header bg-dark text-white">
                <strong class="me-auto">Sistema</strong>
                <small>Agora</small>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
            </div>
            <div class="toast-body">
                @TempData["Mensagem"]
            </div>
        </div>
    </div>
}
