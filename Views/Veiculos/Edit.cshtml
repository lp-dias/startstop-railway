@model StartStop.Models.Veiculo

<h2>Editar Veículo</h2>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <!-- Administrador pode editar placa -->
    @if (User.IsInRole("Administrador"))
    {
        <div class="form-group">
            <label asp-for="Placa" class="control-label"></label>
            <input asp-for="Placa" class="form-control" />
            <span asp-validation-for="Placa" class="text-danger"></span>
        </div>
    }
    else
    {
        <p><strong>Placa:</strong> @Model.Placa</p>
    }

    <!-- Administrador pode editar Km -->
    @if (User.IsInRole("Administrador"))
    {
        <div class="form-group">
            <label asp-for="KmAcumulado" class="control-label"></label>
            <input asp-for="KmAcumulado" class="form-control" />
            <span asp-validation-for="KmAcumulado" class="text-danger"></span>
        </div>
    }
    else
    {
        <p><strong>Kilometragem:</strong> @Model.KmAcumulado</p>
    }

    <!-- Técnico e Administrador podem editar bloqueio -->
    <div class="form-group">
        <label asp-for="Bloqueado" class="control-label"></label>
        <input asp-for="Bloqueado" type="checkbox" />
    </div>

    <div class="form-group">
        <label asp-for="DataInicio" class="control-label"></label>
        <input asp-for="DataInicio" class="form-control" type="datetime-local" />
    </div>

    <div class="form-group">
        <label asp-for="DataFim" class="control-label"></label>
        <input asp-for="DataFim" class="form-control" type="datetime-local" />
    </div>

    <div class="form-group">
        <label asp-for="Oficina" class="control-label"></label>
        <input asp-for="Oficina" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Salvar</button>
    <a asp-action="Index" class="btn btn-secondary">Voltar</a>
</form>
