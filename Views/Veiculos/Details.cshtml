@model StartStop.Models.Veiculo

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Detalhes do Veículo";
}

<h2>Detalhes do Veículo</h2>

<div>
    <h4>Veículo</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Placa</dt>
        <dd class="col-sm-10">@Model.Placa</dd>

        <dt class="col-sm-2">Status</dt>
        <dd class="col-sm-10">@Model.Status</dd>

        <dt class="col-sm-2">Km Acumulado</dt>
        <dd class="col-sm-10">@Model.KmAcumulado</dd>

        <dt class="col-sm-2">Bloqueado</dt>
        <dd class="col-sm-10">@(Model.Bloqueado ? "Sim" : "Não")</dd>

        <dt class="col-sm-2">Data Início</dt>
        <dd class="col-sm-10">@(Model.DataInicio?.ToString("dd/MM/yyyy HH:mm") ?? "-")</dd>

        <dt class="col-sm-2">Data Fim</dt>
        <dd class="col-sm-10">@(Model.DataFim?.ToString("dd/MM/yyyy HH:mm") ?? "-")</dd>

        <dt class="col-sm-2">Oficina</dt>
        <dd class="col-sm-10">@(string.IsNullOrEmpty(Model.Oficina) ? "-" : Model.Oficina)</dd>
    </dl>
</div>

<div>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Voltar
    </a>

    @if (User.IsInRole("Administrador"))
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
            <i class="bi bi-pencil-square"></i> Editar
        </a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
            <i class="bi bi-trash"></i> Excluir
        </a>
    }

    @if (User.IsInRole("Administrador") || User.IsInRole("Tecnico"))
    {
        <form asp-action="ToggleBloqueio" method="post" style="display:inline">
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn @(Model.Bloqueado ? "btn-success" : "btn-danger")">
                @(Model.Bloqueado ? "Desbloquear" : "Bloquear")
            </button>
        </form>
    }
</div>
