@using System.Security.Claims
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StartStop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
</head>
<body>
    <header>
        <!-- Navbar -->
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-car-front-fill me-2"></i> StartStop
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        <!-- Dashboard visível para todos perfis -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Dashboard" asp-action="Index">
                                <i class="bi bi-speedometer2 me-1"></i> Dashboard
                            </a>
                        </li>

                        <!-- Administrador -->
                        @if (User.IsInRole("Administrador"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="cadastrosDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-folder-plus me-1"></i> Cadastros
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Veiculos" asp-action="Index"><i class="bi bi-car-front me-1"></i> Veículos</a></li>
                                    <li><a class="dropdown-item" asp-controller="Usuarios" asp-action="Index"><i class="bi bi-people-fill me-1"></i> Usuários</a></li>
                                </ul>
                            </li>

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-gear-fill me-1"></i> Administração
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Logs" asp-action="Index"><i class="bi bi-journal-text me-1"></i> Log</a></li>
                                    <li><a class="dropdown-item" asp-controller="Motoristas" asp-action="Index"><i class="bi bi-person-badge-fill me-1"></i> Motoristas</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li class="dropdown-header">📊 Relatórios</li>
                                    <li><a class="dropdown-item" asp-controller="Movimentacoes" asp-action="RelatorioPeriodo"><i class="bi bi-calendar-range me-1"></i> Por Período</a></li>
                                    <li><a class="dropdown-item" asp-controller="Movimentacoes" asp-action="RelatorioCombinado"><i class="bi bi-funnel me-1"></i> Por Placa e Motorista</a></li>
                                </ul>
                            </li>
                        }

                        <!-- Motorista e PCO juntos -->
                        @if (User.IsInRole("Motorista") || User.IsInRole("PCO"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="operacoesDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-play-circle-fill me-1"></i> Operações
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Movimentacoes" asp-action="Index"><i class="bi bi-arrow-left-right me-1"></i> Movimentações</a></li>
                                </ul>
                            </li>
                        }

                        <!-- Técnico -->
                        @if (User.IsInRole("Tecnico"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Veiculos" asp-action="Index">Veículos</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Manutencao" asp-action="Index">Manutenções</a>
                            </li>
                        }
                    </ul>

                    <!-- Área de login/logout -->
                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item me-3">
                                <span class="navbar-text text-white">
                                    Olá, @(User.Identity?.Name ?? "Usuário")
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Login" asp-action="Logout">
                                    <i class="bi bi-box-arrow-right me-1"></i> Sair
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Login" asp-action="Index">
                                    <i class="bi bi-box-arrow-in-right me-1"></i> Entrar
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        @if (TempData["ToastMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ToastMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
            </div>
        }

        @RenderBody()
    </div>

    <footer class="bg-light text-center py-3 mt-5 border-top">
        <small class="text-muted">© 2026 - StartStop</small>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
