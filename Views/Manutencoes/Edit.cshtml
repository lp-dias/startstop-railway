@model StartStop.Models.Manutencao
@{
    ViewData["Title"] = "Editar Manutenção";
}

<h2>Editar Manutenção</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="form-group mb-3">
        <label for="VeiculoId">Veículo</label>
        <select asp-for="VeiculoId" class="form-control" asp-items="@(new SelectList(ViewBag.Veiculos, "Id", "Placa", Model.VeiculoId))"></select>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Tipo"></label>
        <input asp-for="Tipo" class="form-control" />
        <span asp-validation-for="Tipo" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="DataInicio"></label>
        <input asp-for="DataInicio" type="date" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label asp-for="DataFim"></label>
        <input asp-for="DataFim" type="date" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label asp-for="Custo"></label>
        <input asp-for="Custo" type="number" step="0.01" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label asp-for="Observacoes"></label>
        <textarea asp-for="Observacoes" class="form-control"></textarea>
        <span asp-validation-for="Observacoes" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
         <label asp-for="Bloqueado"></label>
        <select asp-for="Bloqueado" class="form-control">
        <option value="0">Não</option>
        <option value="1">Sim</option>
        </select>
    </div>


    <button type="submit" class="btn btn-success">Salvar Alterações</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>
