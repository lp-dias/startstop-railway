@model IEnumerable<StartStop.Models.Reserva>

<h2>📌 Reservas</h2>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Veículo</th>
            <th>Usuário</th>
            <th>Data Início</th>
            <th>Data Fim</th>
            <th>Status</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var r in Model)
        {
            <tr>
                <td>@r.Veiculo?.Placa</td>
                <td>@r.Usuario?.Nome</td>
                <td>@r.DataInicio.ToString("dd/MM/yyyy HH:mm")</td>
                <td>@r.DataFim.ToString("dd/MM/yyyy HH:mm")</td>
                <td>@r.Status</td>
                <td>
                    @if (r.Status == "Ativa")
                    {
                        <form asp-action="Finalizar" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@r.Id" />
                            <button type="submit" class="btn btn-success btn-sm">Finalizar</button>
                        </form>
                        <form asp-action="Cancelar" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@r.Id" />
                            <button type="submit" class="btn btn-danger btn-sm">Cancelar</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
