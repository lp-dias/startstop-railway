@model StartStop.Models.Usuario

<h2>Cadastrar Usuário</h2>

<form asp-action="Create" method="post">
    <div>
        <label>Nome</label>
        <input asp-for="Nome" />
    </div>
    <div>
        <label>Email</label>
        <input asp-for="Email" />
    </div>
    <div>
        <label>Perfil</label>
        <input asp-for="Perfil" />
    </div>
    <div>
        <label>Senha</label>
        <input asp-for="SenhaHash" type="password" />
    </div>
    <button type="submit" class="btn btn-success">Salvar</button>
    <a asp-action="Index" class="btn btn-secondary">Voltar</a>
</form>
