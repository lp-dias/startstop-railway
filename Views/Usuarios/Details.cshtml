@model StartStop.Models.Usuario
@using StartStop.Helpers

@{
    ViewData["Title"] = "Detalhes do Usuário";
}

<h2>Detalhes do Usuário</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Nome</dt>
            <dd class="col-sm-9">@Model.Nome</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Perfil</dt>
            <dd class="col-sm-9">@Model.Perfil.GetDisplayName()</dd>

            <dt class="col-sm-3">Último Login</dt>
            <dd class="col-sm-9">
                @(Model.UltimoLogin.HasValue 
                    ? Model.UltimoLogin.Value.ToString("dd/MM/yyyy HH:mm") 
                    : "Nunca logou")
            </dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                @if (Model.Ativo)
                {
                    <span class="badge bg-success">
                        <i class="bi bi-check-circle-fill"></i> Ativo
                    </span>
                }
                else
                {
                    <span class="badge bg-danger">
                        <i class="bi bi-x-circle-fill"></i> Inativo
                    </span>
                }
            </dd>
        </dl>
    </div>
</div>

<p class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
        <i class="bi bi-pencil-square"></i> Editar
    </a>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left-circle"></i> Voltar
    </a>
</p>
